# Copy this file to .env and fill in values before running.

# Maximum upload size in bytes (default 500 MB)
MAX_UPLOAD_BYTES=524288000

# How long (seconds) to keep processed files before cleanup (default 1 hour)
FILE_TTL_SECONDS=3600

# Comma-separated allowed origins for CORS (use * for open access in dev)
CORS_ORIGINS=*
